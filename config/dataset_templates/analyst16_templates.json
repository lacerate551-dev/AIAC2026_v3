[
  {
    "name": "revision_momentum",
    "expression": "rank(vec_avg({field1}) - vec_avg({field2}))",
    "description": "分析师修正动量：上调减下调的净数量，捕捉分析师情绪变化",
    "fields_required": 2,
    "field_types": [["event"], ["event"]],
    "field_hints": {"field1": "anl16_clusterestsup", "field2": "anl16_clusterestsdown"},
    "operators": ["rank", "vec_avg"],
    "category": "pair"
  },
  {
    "name": "revision_ratio",
    "expression": "rank(vec_avg({field1}) / (vec_avg({field2}) + 1))",
    "description": "上调/下调比率，比率>1说明多数分析师看好",
    "fields_required": 2,
    "field_types": [["event"], ["event"]],
    "field_hints": {"field1": "anl16_clusterestsup", "field2": "anl16_clusterestsdown"},
    "operators": ["rank", "vec_avg"],
    "category": "pair"
  },
  {
