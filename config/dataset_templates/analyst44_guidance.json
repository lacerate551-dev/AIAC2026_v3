{
  "dataset_id": "analyst44",
  "dataset_name": "Integrated Broker Estimates",
  "description": "整合券商预估数据，包含分析师共识估值、预期修正、GAAP/非GAAP对比等。数据集同时包含 VECTOR 和 MATRIX 两种类型字段。",
  "field_types": {
    "VECTOR": 649,
    "MATRIX": 148
  },
  "field_type_note": "VECTOR 类型字段（API 返回 type=VECTOR）需要 vec_avg 转换后使用；MATRIX 类型字段（API 返回 type=MATRIX）可直接使用 rank/ts_* 操作符。",

  "research_directions": [
    {
      "name": "盈利预期动量",
      "description": "分析师预期修正动量。4wk_up/dn 为过去4周上调/下调预期数量。",
      "field_patterns": ["anl44_best_*_4wk_up", "anl44_best_*_4wk_dn", "anl44_gaap_best_*_4wk_up"],
      "field_type": "VECTOR",
      "example_template": "rank(vec_avg({field}))",
      "suggested_operators": ["rank", "vec_avg", "ts_delta"]
    },
    {
      "name": "估值共识",
      "description": "分析师估值共识。best_pe_ratio、best_roe 等单值估值指标。",
      "field_patterns": ["anl44_best_pe_ratio", "anl44_best_roe", "anl44_best_ebit_to_sales"],
      "field_type": "VECTOR",
      "example_template": "rank(vec_avg({field}))",
      "suggested_operators": ["rank", "vec_avg"]
    },
    {
      "name": "预期差",
      "description": "当年vs下年预期差异。eeps_cur_yr/nxt_yr 字段为 MATRIX 类型。",
      "field_patterns": ["anl44_*_best_eeps_cur_yr", "anl44_*_best_eeps_nxt_yr"],
      "field_type": "MATRIX",
      "example_template": "rank({field1}) - rank({field2})",
      "suggested_operators": ["rank", "ts_zscore", "group_rank"]
    },
    {
      "name": "财年度盈利",
      "description": "财年度盈利指标。fiscal_qtr_period/fiscal_year_period 等为 MATRIX 类型。",
      "field_patterns": ["anl44_*_best_cur_fiscal_*", "anl44_*_best_crncy_iso"],
      "field_type": "MATRIX",
      "example_template": "rank({field})",
      "suggested_operators": ["rank", "group_rank", "ts_mean"]
    }
  ],

